# Vorlage fuer STAGING. Lokal als ".env.staging" speichern (gitignored).
# Diese Datei wird vom Deploy-Skript abgleich/deploy-staging.ps1 ausschliesslich
# explizit ueber den Parameter -EnvFile referenziert. Der Inhalt landet auf dem
# STAGING-Server als ".env" im konfigurierten -RemoteRepo.
#
# WICHTIG:
# - Niemals echte Secrets ins Repository committen.
# - STAGING ist eine eigenstaendige Umgebung: eigene DB, eigene MinIO-Instanz,
#   eigener JWT_SECRET. Werte duerfen NICHT mit TEST oder PROD identisch sein.
# - DATABASE_URL muss das aktuell aktive Postgres-Volume-Passwort enthalten
#   (POSTGRES_PASSWORD greift nur beim ersten Initialisieren des Volumes).

# --- Datenbank (STAGING) ---
DATABASE_URL=postgresql://postgres:CHANGE_ME_STAGING_DB_PASS@postgres:5432/crm_monteur
POSTGRES_PASSWORD=CHANGE_ME_STAGING_DB_PASS

# --- Auth ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STAGING_SECRET

# --- Ports / Web ---
API_PORT=3801
WEB_PORT=3800
NEXT_PUBLIC_API_URL=/api

# --- Object Storage (MinIO STAGING) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=CHANGE_ME_STAGING_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_STAGING_MINIO_PASS
MINIO_BUCKET=crm-documents
MINIO_USE_SSL=false
MINIO_BROWSER_REDIRECT_URL=https://CHANGE_ME_STAGING_S3_DOMAIN
STORAGE_LOCAL_FALLBACK=false

# --- Mailversand ---
# Empfehlung: STAGING entweder gegen einen MailHog/Mailcatcher oder eine
# separate, gedrosselte SMTP-Adresse, damit Test-Mails nicht an reale
# Empfaenger gehen.
SMTP_HOST=CHANGE_ME_STAGING_SMTP_HOST
SMTP_PORT=587
SMTP_USER=CHANGE_ME_STAGING_SMTP_USER
SMTP_PASS=CHANGE_ME_STAGING_SMTP_PASS
SMTP_FROM=CHANGE_ME_STAGING_SMTP_FROM

# --- Notfall-Admin (auf STAGING ueblicherweise deaktiviert) ---
EMERGENCY_ADMIN_ENABLED=false
EMERGENCY_ADMIN_USER=
EMERGENCY_ADMIN_PASS=
EMERGENCY_ADMIN_TTL_MINUTES=20
EMERGENCY_ADMIN_ALLOWED_IPS=
EMERGENCY_ADMIN_REQUIRE_HEADER=
