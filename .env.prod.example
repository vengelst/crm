# Vorlage fuer Produktion. Lokal als ".env.prod" speichern (gitignored).
# Diese Datei wird vom Deploy-Skript abgleich/deploy-prod.ps1 ausschliesslich
# explizit ueber den Parameter -EnvFile referenziert. Der Inhalt landet auf dem
# PROD-Server als ".env" im konfigurierten -RemoteRepo.
#
# WICHTIG:
# - Niemals echte Secrets ins Repository committen.
# - DATABASE_URL muss das aktuell aktive Postgres-Volume-Passwort enthalten
#   (POSTGRES_PASSWORD greift nur beim ersten Initialisieren des Volumes).
# - JWT_SECRET fuer PROD muss sich von TEST unterscheiden.

# --- Datenbank (PROD) ---
# Container-intern: Host "postgres", Port 5432.
DATABASE_URL=postgresql://postgres:CHANGE_ME_PROD_DB_PASS@postgres:5432/crm_monteur
POSTGRES_PASSWORD=CHANGE_ME_PROD_DB_PASS

# --- Auth ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_PROD_SECRET

# --- Ports / Web ---
API_PORT=3801
WEB_PORT=3800
NEXT_PUBLIC_API_URL=/api

# --- Object Storage (MinIO PROD) ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=CHANGE_ME_PROD_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_PROD_MINIO_PASS
MINIO_BUCKET=crm-documents
MINIO_USE_SSL=false
MINIO_BROWSER_REDIRECT_URL=https://CHANGE_ME_PROD_S3_DOMAIN
STORAGE_LOCAL_FALLBACK=false

# --- Mailversand ---
SMTP_HOST=CHANGE_ME_PROD_SMTP_HOST
SMTP_PORT=587
SMTP_USER=CHANGE_ME_PROD_SMTP_USER
SMTP_PASS=CHANGE_ME_PROD_SMTP_PASS
SMTP_FROM=CHANGE_ME_PROD_SMTP_FROM

# --- Notfall-Admin (Default: deaktiviert) ---
EMERGENCY_ADMIN_ENABLED=false
EMERGENCY_ADMIN_USER=
EMERGENCY_ADMIN_PASS=
EMERGENCY_ADMIN_TTL_MINUTES=20
EMERGENCY_ADMIN_ALLOWED_IPS=
EMERGENCY_ADMIN_REQUIRE_HEADER=
