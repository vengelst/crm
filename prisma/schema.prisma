generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum RoleCode {
  SUPERADMIN
  OFFICE
  PROJECT_MANAGER
  WORKER
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum ProjectStatus {
  DRAFT
  PLANNED
  ACTIVE
  PAUSED
  COMPLETED
  CANCELED
}

enum ServiceType {
  VIDEO
  ELECTRICAL
  SERVICE
  OTHER
}

enum BreakScopeType {
  GLOBAL
  PROJECT
}

enum TimeEntryType {
  CLOCK_IN
  CLOCK_OUT
  MANUAL_ADJUSTMENT
}

enum GpsEventType {
  CLOCK_IN
  CLOCK_OUT
  MANUAL
}

enum WeeklyTimesheetStatus {
  DRAFT
  WORKER_SIGNED
  CUSTOMER_SIGNED
  COMPLETED
  APPROVED
  BILLED
  LOCKED
}

enum DocumentApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
}

enum OfficeReminderStatus {
  OPEN
  COMPLETED
  CANCELED
}

enum OfficeReminderKind {
  TODO
  CALLBACK
  FOLLOW_UP
}

enum SignerType {
  WORKER
  CUSTOMER
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  passwordHash String
  kioskCodeHash String?
  displayName String
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  roles       UserRole[]
  sessions    Session[]
  managedProjects Project[] @relation("ProjectManager")
  uploadedDocuments Document[]
  createdCustomerCallLogs CustomerCallLog[]
  auditLogs   AuditLog[]
  kioskDevices KioskDevice[]
  notifications Notification[]
  createdNotes  Note[]           @relation("NoteCreator")
  assignedOfficeReminders OfficeReminder[] @relation("OfficeReminderAssignee")
  createdOfficeReminders  OfficeReminder[] @relation("OfficeReminderCreator")
  completedOfficeReminders OfficeReminder[] @relation("OfficeReminderCompleter")
}

model Role {
  id        String     @id @default(cuid())
  code      RoleCode   @unique
  name      String
  createdAt   DateTime         @default(now())
  users       UserRole[]
  permissions RolePermission[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  category    String
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model SmtpConfig {
  id        String   @id @default(cuid())
  host      String
  port      Int      @default(587)
  user      String?
  password  String?
  fromEmail String
  secure    Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String?
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Customer {
  id             String            @id @default(cuid())
  customerNumber String            @unique
  companyName    String
  legalForm      String?
  status         CustomerStatus    @default(ACTIVE)
  billingEmail   String?
  phone          String?
  email          String?
  website        String?
  vatId          String?
  addressLine1   String?
  addressLine2   String?
  postalCode     String?
  city           String?
  country        String?
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  branches       CustomerBranch[]
  contacts       CustomerContact[]
  projects       Project[]
  callLogs       CustomerCallLog[]
  crmNotes       Note[]
  customerNotes  CustomerNote[]
  officeReminders OfficeReminder[]
}

model CustomerBranch {
  id           String           @id @default(cuid())
  customerId   String
  name         String
  addressLine1 String?
  addressLine2 String?
  postalCode   String?
  city         String?
  country      String?
  phone        String?
  email        String?
  notes        String?
  active       Boolean          @default(true)
  customer     Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contacts     CustomerContact[]
  projects     Project[]
}

model CustomerContact {
  id                  String           @id @default(cuid())
  customerId          String
  branchId            String?
  firstName           String
  lastName            String
  role                String?
  email               String?
  phoneMobile         String?
  phoneLandline       String?
  isAccountingContact Boolean          @default(false)
  isProjectContact    Boolean          @default(false)
  isSignatory         Boolean          @default(false)
  notes               String?
  customer            Customer         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch              CustomerBranch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  primaryProjects     Project[]        @relation("ProjectPrimaryContact")
  crmNotes            Note[]
  officeReminders     OfficeReminder[]
}

model Project {
  id                           String                @id @default(cuid())
  projectNumber                String                @unique
  customerId                   String
  branchId                     String?
  title                        String
  description                  String?
  serviceType                  ServiceType           @default(OTHER)
  status                       ProjectStatus         @default(DRAFT)
  priority                     Int                   @default(0)
  siteName                     String?
  siteAddressLine1             String?
  sitePostalCode               String?
  siteCity                     String?
  siteCountry                  String?
  siteLatitude                 Float?
  siteLongitude                Float?
  accommodationAddress         String?
  weeklyFlatRate               Float?
  includedHoursPerWeek         Float?
  hourlyRateUpTo40h            Float?
  overtimeRate                 Float?
  plannedStartDate             DateTime?
  plannedEndDate               DateTime?
  actualStartDate              DateTime?
  actualEndDate                DateTime?
  internalProjectManagerUserId String?
  primaryCustomerContactId     String?
  pauseRuleId                  String?
  notes                        String?
  billingReady                 Boolean               @default(false)
  billingReadyAt               DateTime?
  billingReadyByUserId         String?
  billingReadyComment          String?
  createdAt                    DateTime              @default(now())
  updatedAt                    DateTime              @updatedAt
  deletedAt                    DateTime?
  customer                     Customer              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  branch                       CustomerBranch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  internalProjectManager       User?                 @relation("ProjectManager", fields: [internalProjectManagerUserId], references: [id], onDelete: SetNull)
  primaryCustomerContact       CustomerContact?      @relation("ProjectPrimaryContact", fields: [primaryCustomerContactId], references: [id], onDelete: SetNull)
  pauseRule                    BreakRule?            @relation(fields: [pauseRuleId], references: [id], onDelete: SetNull)
  assignments                  ProjectAssignment[]
  linkedNotes                  Note[]                @relation("NoteProject")
  timeEntries                  TimeEntry[]
  gpsEvents                    GpsEvent[]
  weeklyTimesheets             WeeklyTimesheet[]
  projectNotes                 ProjectNote[]
  checklists                   ProjectChecklist[]
  notices                      ProjectNotice[]
  noticeAcknowledgements       ProjectNoticeAcknowledgement[]
  officeReminders              OfficeReminder[]
}

model Worker {
  id            String                    @id @default(cuid())
  workerNumber  String                    @unique
  firstName     String
  lastName      String
  email         String?
  phone         String?
  phoneMobile   String?
  phoneOffice   String?
  addressLine1  String?
  addressLine2  String?
  postalCode    String?
  city          String?
  country       String?
  active        Boolean                   @default(true)
  internalHourlyRate Float?
  languageCode  String?
  notes         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  pins          WorkerPin[]
  assignments   ProjectAssignment[]
  timeEntries   TimeEntry[]
  gpsEvents     GpsEvent[]
  weeklyTimesheets WeeklyTimesheet[]
  uploadedDocuments Document[]
  vehicleAssignments WorkerVehicleAssignment[]
  equipmentIssues WorkerEquipmentIssue[]
  teamMemberships WorkerTeamMember[]
  kioskDevices    KioskDevice[]
  notifications   Notification[]
  noticeAcknowledgements ProjectNoticeAcknowledgement[]
}

model WorkerTeam {
  id        String             @id @default(cuid())
  name      String
  notes     String?
  active    Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  members   WorkerTeamMember[]
}

model WorkerTeamMember {
  id       String     @id @default(cuid())
  teamId   String
  workerId String
  role     String?
  joinedAt DateTime   @default(now())
  team     WorkerTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  worker   Worker     @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([teamId, workerId])
}

model WorkerPin {
  id        String   @id @default(cuid())
  workerId  String
  pinHash   String
  validFrom DateTime @default(now())
  validTo   DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model ProjectAssignment {
  id        String    @id @default(cuid())
  projectId String
  workerId  String
  roleName  String?
  startDate DateTime
  endDate   DateTime?
  active    Boolean   @default(true)
  notes     String?
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker    Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([projectId, workerId])
}

model Vehicle {
  id           String                    @id @default(cuid())
  licensePlate String                    @unique
  make         String?
  model        String?
  internalName String?
  active       Boolean                   @default(true)
  notes        String?
  assignments  WorkerVehicleAssignment[]
}

model WorkerVehicleAssignment {
  id           String    @id @default(cuid())
  workerId     String
  vehicleId    String
  assignedFrom DateTime
  assignedTo   DateTime?
  notes        String?
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model EquipmentItem {
  id           String                 @id @default(cuid())
  itemNumber   String                 @unique
  category     String
  name         String
  serialNumber String?
  trackable    Boolean                @default(true)
  active       Boolean                @default(true)
  notes        String?
  issues       WorkerEquipmentIssue[]
}

model WorkerEquipmentIssue {
  id              String         @id @default(cuid())
  workerId        String
  equipmentItemId String
  issuedAt        DateTime
  returnedAt      DateTime?
  conditionOut    String?
  conditionIn     String?
  notes           String?
  worker          Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  equipmentItem   EquipmentItem  @relation(fields: [equipmentItemId], references: [id], onDelete: Cascade)
}

model BreakRule {
  id               String          @id @default(cuid())
  scopeType        BreakScopeType
  name             String
  autoDeductEnabled Boolean        @default(true)
  thresholdMinutes1 Int
  breakMinutes1    Int
  thresholdMinutes2 Int?
  breakMinutes2    Int?
  active           Boolean         @default(true)
  projects         Project[]
}

model TimeEntry {
  id                String         @id @default(cuid())
  workerId          String
  projectId         String
  entryType         TimeEntryType
  occurredAtClient  DateTime
  occurredAtServer  DateTime       @default(now())
  latitude          Float?
  longitude         Float?
  accuracy          Float?
  locationSource    String?
  comment           String?
  sourceDevice      String?
  createdByUserId   String?
  kioskSessionId    String?
  deviceUuid        String?
  deviceDisplayName String?
  worker            Worker         @relation(fields: [workerId], references: [id], onDelete: Cascade)
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workerId, projectId, occurredAtServer])
}

model GpsEvent {
  id                 String        @id @default(cuid())
  workerId           String
  projectId          String?
  relatedTimeEntryId String?
  latitude           Float
  longitude          Float
  accuracy           Float?
  recordedAt         DateTime      @default(now())
  eventType          GpsEventType
  worker             Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)
  project            Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

model WeeklyTimesheet {
  id               String                 @id @default(cuid())
  workerId         String
  projectId        String
  weekYear         Int
  weekNumber       Int
  status           WeeklyTimesheetStatus  @default(DRAFT)
  totalMinutesGross Int                   @default(0)
  totalBreakMinutes Int                   @default(0)
  totalMinutesNet  Int                    @default(0)
  generatedAt      DateTime               @default(now())
  lockedAt         DateTime?
  approvedAt       DateTime?
  approvedByUserId String?
  approvalComment  String?
  billedAt         DateTime?
  billedByUserId   String?
  worker           Worker                 @relation(fields: [workerId], references: [id], onDelete: Cascade)
  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  days             WeeklyTimesheetDay[]
  signatures       WeeklyTimesheetSignature[]

  @@unique([workerId, projectId, weekYear, weekNumber])
}

model WeeklyTimesheetDay {
  id                   String           @id @default(cuid())
  weeklyTimesheetId    String
  workDate             DateTime
  firstClockInAt       DateTime?
  lastClockOutAt       DateTime?
  grossMinutes         Int              @default(0)
  breakMinutes         Int              @default(0)
  netMinutes           Int              @default(0)
  summaryComment       String?
  clockInLatitude      Float?
  clockInLongitude     Float?
  clockOutLatitude     Float?
  clockOutLongitude    Float?
  weeklyTimesheet      WeeklyTimesheet  @relation(fields: [weeklyTimesheetId], references: [id], onDelete: Cascade)
}

model WeeklyTimesheetSignature {
  id                 String           @id @default(cuid())
  weeklyTimesheetId  String
  signerType         SignerType
  signerName         String
  signerRole         String?
  signatureImagePath String
  signedAt           DateTime         @default(now())
  ipAddress          String?
  deviceInfo         String?
  weeklyTimesheet    WeeklyTimesheet  @relation(fields: [weeklyTimesheetId], references: [id], onDelete: Cascade)
}

model Document {
  id                 String                 @id @default(cuid())
  storageKey         String                 @unique
  originalFilename   String
  mimeType           String
  fileSize           Int
  uploadedByUserId   String?
  uploadedByWorkerId String?
  documentType       String
  title              String?
  description        String?
  approvalStatus     DocumentApprovalStatus @default(DRAFT)
  approvedAt         DateTime?
  approvedByUserId   String?
  approvalComment    String?
  createdAt          DateTime               @default(now())
  uploadedBy         User?                  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  uploadedByWorker   Worker?                @relation(fields: [uploadedByWorkerId], references: [id], onDelete: SetNull)
  links              DocumentLink[]
}

model DocumentLink {
  id         String   @id @default(cuid())
  documentId String
  entityType String
  entityId   String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model CustomerCallLog {
  id              String    @id @default(cuid())
  customerId      String
  contactId       String?
  projectId       String?
  subject         String
  callDate        DateTime
  direction       String
  summary         String
  nextAction      String?
  createdByUserId String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdByUser   User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
}

model CustomerNote {
  id              String    @id @default(cuid())
  customerId      String
  body            String
  createdAt       DateTime  @default(now())
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model ProjectNote {
  id              String    @id @default(cuid())
  projectId       String
  body            String
  createdAt       DateTime  @default(now())
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueJson Json
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorType   String
  entityType  String
  entityId    String
  action      String
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
}

model KioskDevice {
  id               String    @id @default(cuid())
  deviceUuid       String    @unique
  displayName      String?
  platform         String?
  browser          String?
  userAgent        String?
  firstSeenAt      DateTime  @default(now())
  lastSeenAt       DateTime  @default(now())
  active           Boolean   @default(false)
  notes            String?
  assignedWorkerId String?
  assignedUserId   String?
  assignedWorker   Worker?   @relation(fields: [assignedWorkerId], references: [id], onDelete: SetNull)
  assignedUser     User?     @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
}

model ProjectChecklist {
  id          String               @id @default(cuid())
  projectId   String
  name        String
  description String?
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  project     Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items       ProjectChecklistItem[]

  @@index([projectId])
}

model ProjectChecklistItem {
  id              String           @id @default(cuid())
  checklistId     String
  title           String
  description     String?
  sortOrder       Int              @default(0)
  completed       Boolean          @default(false)
  completedAt     DateTime?
  completedByName String?
  completedById   String?
  comment         String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  checklist       ProjectChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  @@index([checklistId])
}

model ChecklistTemplate {
  id          String                    @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  items       ChecklistTemplateItem[]
  notices     ChecklistTemplateNotice[]
}

model ChecklistTemplateNotice {
  id               String            @id @default(cuid())
  templateId       String
  title            String
  body             String
  sortOrder        Int               @default(0)
  required         Boolean           @default(false)
  requireSignature Boolean           @default(false)
  template         ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model ChecklistTemplateItem {
  id          String            @id @default(cuid())
  templateId  String
  title       String
  description String?
  sortOrder   Int               @default(0)
  template    ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Notification {
  id             String    @id @default(cuid())
  recipientType  String    // "user" | "worker"
  recipientUserId  String?
  recipientWorkerId String?
  type           String    // ASSIGNMENT, SIGNATURE, APPROVAL, MISSING_TIME, INFO
  title          String
  body           String?
  linkType       String?   // PROJECT, TIMESHEET, DOCUMENT
  linkId         String?
  read           Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())
  recipientUser  User?     @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  recipientWorker Worker?  @relation(fields: [recipientWorkerId], references: [id], onDelete: Cascade)

  @@index([recipientUserId, read])
  @@index([recipientWorkerId, read])
}

model ReminderLog {
  id          String   @id @default(cuid())
  type        String
  entityId    String
  channel     String   // EMAIL, IN_APP, SMS, PUSH
  recipientId String
  sentAt      DateTime @default(now())
  status      String   @default("SENT") // SENT, FAILED

  @@unique([type, entityId, channel, recipientId])
  @@index([type, entityId])
}

model ProjectNotice {
  id                      String                       @id @default(cuid())
  projectId               String
  sourceTemplateId        String?
  sourceTemplateNoticeId  String?
  title                   String
  body                    String
  sortOrder               Int                          @default(0)
  required                Boolean                      @default(false)
  requireSignature        Boolean                      @default(false)
  active                  Boolean                      @default(true)
  createdAt               DateTime                     @default(now())
  updatedAt               DateTime                     @updatedAt
  project                 Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  acknowledgements        ProjectNoticeAcknowledgement[]

  @@index([projectId])
}

model ProjectNoticeAcknowledgement {
  id                 String        @id @default(cuid())
  projectNoticeId    String
  projectId          String
  workerId           String
  acknowledged       Boolean       @default(false)
  acknowledgedAt     DateTime?
  signatureImagePath String?
  comment            String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  projectNotice      ProjectNotice @relation(fields: [projectNoticeId], references: [id], onDelete: Cascade)
  project            Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  worker             Worker        @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([projectNoticeId, workerId])
  @@index([projectId, workerId])
}

model Note {
  id              String           @id @default(cuid())
  entityType      String           // CUSTOMER | CONTACT
  customerId      String?
  contactId       String?
  projectId       String?
  title           String?
  content         String
  isPhoneNote     Boolean          @default(false)
  transcriptSource String?
  audioPath       String?
  createdByUserId String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contact         CustomerContact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  project         Project?         @relation("NoteProject", fields: [projectId], references: [id], onDelete: SetNull)
  createdBy       User             @relation("NoteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  officeReminders OfficeReminder[]

  @@index([customerId])
  @@index([contactId])
  @@index([projectId])
  @@index([createdAt])
}

model OfficeReminder {
  id                String               @id @default(cuid())
  title             String
  description       String?
  kind              OfficeReminderKind   @default(TODO)
  status            OfficeReminderStatus @default(OPEN)
  dueAt             DateTime?
  remindAt          DateTime
  channels          String[]             @default([])
  smsNumber         String?
  assignedUserId    String
  createdByUserId   String
  completedByUserId String?
  completedAt       DateTime?
  customerId        String?
  contactId         String?
  projectId         String?
  noteId            String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  assignedUser      User                 @relation("OfficeReminderAssignee", fields: [assignedUserId], references: [id], onDelete: Cascade)
  createdBy         User                 @relation("OfficeReminderCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  completedBy       User?                @relation("OfficeReminderCompleter", fields: [completedByUserId], references: [id], onDelete: SetNull)
  customer          Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  contact           CustomerContact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  project           Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  note              Note?                @relation(fields: [noteId], references: [id], onDelete: SetNull)

  @@index([status, remindAt])
  @@index([assignedUserId, status])
  @@index([customerId])
  @@index([contactId])
  @@index([projectId])
  @@index([noteId])
}

model Counter {
  id      String @id          // e.g. "CUSTOMER", "PROJECT"
  prefix  String              // e.g. "K", "P"
  current Int                 // last issued number
}
