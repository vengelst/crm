# Lokal (API auf dem Host): 127.0.0.1 + Port-Mapping.
# Docker-Stack auf Server: Host "postgres", Port 5432; Passwort = POSTGRES_PASSWORD (muss in der URL stehen).
# POSTGRES_PASSWORD wirkt nur beim ersten Start mit leerem Volume — bestehendes Volume behält altes Passwort.
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/crm_monteur
JWT_SECRET=change-me
API_PORT=3801
WEB_PORT=3800
NEXT_PUBLIC_API_URL=http://localhost:3801
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=crm-documents
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=crm@example.local

# ── Notfall-/Break-Glass-Admin ──────────────────────────────────────────────
# Authentifiziert ausschliesslich gegen ENV (kein DB-Lookup). Im Erfolgsfall
# JWT mit type=emergency-admin, roles=[SUPERADMIN], permissions=["*"], kurze
# TTL. Standardmaessig vollstaendig deaktiviert.
#
# Aktivierung NUR in Notfaellen — niemals echte Credentials in das Repo
# einchecken oder in .env Dateien aktiv lassen, die ausgerollt werden.
EMERGENCY_ADMIN_ENABLED=false
EMERGENCY_ADMIN_USER=
EMERGENCY_ADMIN_PASS=
# Optionale Haerterungen:
# EMERGENCY_ADMIN_TTL_MINUTES   (Default 20, Clamp 5..60)
# EMERGENCY_ADMIN_ALLOWED_IPS   (CSV, leer = jede Quell-IP zulaessig)
# EMERGENCY_ADMIN_REQUIRE_HEADER  Format: "Header-Name=expected-value"
EMERGENCY_ADMIN_TTL_MINUTES=20
EMERGENCY_ADMIN_ALLOWED_IPS=
EMERGENCY_ADMIN_REQUIRE_HEADER=
