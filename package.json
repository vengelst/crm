{
  "name": "crm-monteur-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d --build",
    "dev:docker:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f",
    "dev:docker:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "prisma generate --schema ./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --config ./prisma/prisma.config.ts",
    "db:seed": "pnpm --filter api db:seed",
    "format": "turbo run format"
  },
  "devDependencies": {
    "prisma": "^7.5.0",
    "turbo": "^2.5.8"
  },
  "dependencies": {
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "7.5.0"
  }
}
